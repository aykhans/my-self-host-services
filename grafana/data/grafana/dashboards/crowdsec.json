          "refId": "A",
          "instant": true,
          "format": "table",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheusdatasource"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "origin": true
            },
            "indexByName": {
              "country": 0,
              "ip": 1,
              "scenario": 2,
              "type": 3,
              "Value": 4
            },
            "renameByName": {
              "country": "Country",
              "ip": "IP",
              "scenario": "Scenario",
              "type": "Type",
              "Value": "Time remaining"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true,
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Time remaining"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Time remaining",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        }
